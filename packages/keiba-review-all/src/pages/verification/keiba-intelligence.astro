---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'keiba-intelligence 検証結果 | keiba-review';
const description = 'keiba-intelligenceのAI予想の検証結果を詳しく紹介。南関競馬とJRAの月別実績データ、的中率、回収率を公開しています。';
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-8 md:py-12">
    <!-- パンくずリスト -->
    <nav class="mb-6 text-sm text-gray-600">
      <a href="/" class="hover:text-blue-600">ホーム</a>
      <span class="mx-2">&gt;</span>
      <a href="/keiba-yosou" class="hover:text-blue-600">サイト一覧</a>
      <span class="mx-2">&gt;</span>
      <a href="/keiba-yosou/keiba-intelligence-jp" class="hover:text-blue-600">keiba-intelligence</a>
      <span class="mx-2">&gt;</span>
      <span>検証結果</span>
    </nav>

    <!-- メインタイトル -->
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-8">
      keiba-intelligence 検証結果
    </h1>

    <!-- 概要 -->
    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl border-2 border-blue-200 p-6 md:p-8 mb-8">
      <p class="text-base md:text-lg text-gray-700 leading-relaxed mb-4">
        このページでは、keiba-intelligenceのAI予想の実績データを詳しく紹介しています。
      </p>
      <p class="text-base md:text-lg text-gray-700 leading-relaxed">
        南関競馬とJRAそれぞれの月別成績が公式サイトで公開されており、的中率や回収率を確認できます。
      </p>
    </div>

    <!-- 南関競馬セクション -->
    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">🌃</span>
        南関競馬
      </h2>

      <!-- 実績データ -->
      <div class="bg-white rounded-xl shadow-lg p-6 md:p-8 mb-6 border border-gray-200">
        <h3 class="text-xl font-bold text-gray-900 mb-6">直近の実績データ</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">的中率</p>
            <p class="text-4xl font-bold text-green-600">約72%</p>
          </div>
          <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">回収率</p>
            <p class="text-4xl font-bold text-amber-600">約255%</p>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">対象レース</p>
            <p class="text-4xl font-bold text-blue-600">100+</p>
            <p class="text-xs text-gray-500 mt-1">大井・川崎・船橋・浦和</p>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-4">📊 月別の詳細データを見る</h4>
          <p class="text-gray-700 mb-4 leading-relaxed">
            keiba-intelligence公式サイトでは、南関4場（大井・川崎・船橋・浦和）の月別実績を公開しています。各月の的中率、回収率、レース数、合計配当などを確認できます。
          </p>
          <a
            href="https://keiba-intelligence.jp/archive"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 !text-white px-6 py-3 rounded-lg font-bold transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105"
          >
            <span class="!text-white">南関競馬の月別実績ページへ</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- JRAセクション -->
    <section class="mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 flex items-center gap-3">
        <span class="text-3xl">🏇</span>
        JRA（中央競馬）
      </h2>

      <!-- 実績データ -->
      <div class="bg-white rounded-xl shadow-lg p-6 md:p-8 mb-6 border border-gray-200">
        <h3 class="text-xl font-bold text-gray-900 mb-6">直近の実績データ</h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">的中率</p>
            <p class="text-4xl font-bold text-green-600">約70%</p>
          </div>
          <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">回収率</p>
            <p class="text-4xl font-bold text-amber-600">約347%</p>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-6 text-center">
            <p class="text-sm text-gray-600 mb-2">対象レース</p>
            <p class="text-4xl font-bold text-blue-600">150+</p>
            <p class="text-xs text-gray-500 mt-1">全10場</p>
          </div>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-4">📊 月別の詳細データを見る</h4>
          <p class="text-gray-700 mb-4 leading-relaxed">
            keiba-intelligence公式サイトでは、JRA全10場の月別実績を公開しています。各月の的中率、回収率、レース数、合計配当などを確認できます。
          </p>
          <a
            href="https://keiba-intelligence.jp/archive-jra"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 !text-white px-6 py-3 rounded-lg font-bold transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105"
          >
            <span class="!text-white">JRAの月別実績ページへ</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- 注記 -->
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-lg mb-8">
      <p class="text-sm text-gray-700 leading-relaxed">
        <strong class="font-bold">※注意事項</strong><br>
        上記のデータは、keiba-intelligence公式サイトで公開されている実績データに基づいています。実際の利用時の結果を保証するものではありません。投資判断は自己責任でお願いします。
      </p>
    </div>

    <!-- レビューページへ戻るリンク -->
    <div class="text-center">
      <a
        href="/keiba-yosou/keiba-intelligence-jp"
        class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-bold transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span>keiba-intelligenceのレビューページへ戻る</span>
      </a>
    </div>
  </div>
</BaseLayout>
