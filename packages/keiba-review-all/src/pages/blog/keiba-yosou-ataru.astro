---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const breadcrumbItems = [
  { label: 'コラム', href: '/blog/' },
  { label: '競馬予想 当たる サイト' }
];
---

<BaseLayout
